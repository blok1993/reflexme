{
  "name": "predictor-monorepo",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "prisma": {
    "schema": "apps/backend/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w @predictor/backend\" \"npm run dev -w @predictor/frontend\"",
    "start": "npm run start -w @predictor/backend",
    "build:backend": "node scripts/run-prisma.cjs generate && npm run build -w @predictor/backend",
    "build": "npm run build -ws",
    "prisma:generate": "node scripts/run-prisma.cjs generate",
    "prisma:push": "node scripts/run-prisma.cjs db push",
    "prisma:studio": "node scripts/run-prisma.cjs studio",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:backend": "npm run test -w @predictor/backend",
    "test:all": "npm run test:backend && npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.0.1"
  }
}
