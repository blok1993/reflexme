PORT=3001
NODE_ENV=development

# PostgreSQL — use a managed service for production
# Supabase: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
# Neon:     postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require
# Local:    postgresql://localhost:5432/predictor
DATABASE_URL="postgresql://localhost:5432/predictor"

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# Allowed frontend origin for CORS (in production set to your frontend URL)
# FRONTEND_URL=https://your-app.vercel.app
